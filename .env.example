# ===========================================
# NexusNote 环境配置模板
# ===========================================
# 复制此文件为 .env 并填入你的配置
# 只列出必需变量和常用可选变量，其余均有合理默认值

# ===========================================
# 必需变量（不配置无法启动）
# ===========================================

# PostgreSQL 连接字符串
DATABASE_URL=postgresql://user:password@localhost:5432/nexusnote

# Redis 连接字符串（用于队列和分布式锁）
REDIS_URL=redis://localhost:6379

# Auth.js v5 加密密钥（生产环境：openssl rand -base64 32）
AUTH_SECRET=your-random-32-char-auth-secret-change-in-production

# 登录方式
# 生产默认使用 Resend；非生产默认使用直接登录。
# 如果预览环境以 NODE_ENV=production 构建，可显式打开直接登录。
# AUTH_RESEND_ENABLED=true
# AUTH_DEV_LOGIN_ENABLED=true
# NEXT_PUBLIC_AUTH_RESEND_ENABLED=true
# NEXT_PUBLIC_AUTH_DEV_LOGIN_ENABLED=true

# AI Provider（至少配置一个）
AI_302_API_KEY=sk-your-302ai-api-key

# ===========================================
# 可选：备选 AI Provider
# ===========================================

# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# OPENAI_API_KEY=sk-your-openai-api-key
# SILICONFLOW_API_KEY=sk-your-siliconflow-api-key
# TAVILY_API_KEY=your-tavily-api-key

# ===========================================
# 可选：AI 可观测性（Langfuse）
# ===========================================
# 功能：自动追踪 tokens、成本、延迟、工具调用
# 注册地址：https://langfuse.com/signup（免费）

# LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
# LANGFUSE_SECRET_KEY=sk-lf-your-secret-key

# ===========================================
# 可选：覆盖默认 AI 模型
# ===========================================
# 以下均有默认值，一般不需要修改

# AI_MODEL_INTERACTIVE=qwen-plus-latest
# AI_MODEL_OUTLINE=gpt-5.4-mini
# AI_MODEL_SECTION_DRAFT=qwen-plus-latest
# AI_MODEL_EXTRACT=qwen-plus-latest
# AI_MODEL_REVIEW=gpt-5.5
# AI_MODEL_WEB_SEARCH=gpt-5.4-mini
# AI_ENABLE_WEB_SEARCH=false

# ===========================================
# 可选：RAG 调优参数
# ===========================================
# 以下均有默认值，仅在需要微调时修改

# EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# EMBEDDING_DIMENSIONS=4096
# RERANKER_MODEL=Qwen/Qwen3-Reranker-4B
# RERANKER_MODEL_PRO=Qwen/Qwen3-Reranker-8B
# RERANKER_ENABLED=false
# RAG_CHUNK_SIZE=500
# RAG_CHUNK_OVERLAP=50
# RAG_TIMEOUT=5000
# RAG_SIMILARITY_THRESHOLD=0.3
