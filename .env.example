# ===========================================
# NexusNote 环境配置模板
# ===========================================
# 复制此文件为 .env 并填入你的配置
# 只列出必需变量和常用可选变量，其余均有合理默认值

# ===========================================
# 必需变量（不配置无法启动）
# ===========================================

# PostgreSQL 连接字符串
DATABASE_URL=postgresql://user:password@localhost:5432/nexusnote

# Redis 连接字符串（用于队列和分布式锁）
REDIS_URL=redis://localhost:6379

# Auth.js v5 加密密钥（生产环境：openssl rand -base64 32）
AUTH_SECRET=your-random-32-char-auth-secret-change-in-production

# 登录方式
# 只保留 Resend 邮件链接登录。登录链接短时间内可重复使用，避免邮件客户端预打开导致失效。
# AUTH_RESEND_ENABLED=true

# AI Provider（至少配置一个）
AI_302_API_KEY=sk-your-302ai-api-key
AI_302_BASE_URL=https://api.302ai.cn/v1
# 302 同时用于主模型和 research Qwen3 reranker。

# 可选：支付
# BILLING_PROVIDER=302pay
# BILLING_302PAY_API_KEY=sk-your-302pay-api-key
# BILLING_302PAY_BASE_URL=https://api.302.ai

# 联网 / research
# Tavily: agent search + extract；Exa: semantic/deep web；Jina: AI-native search/reader；Firecrawl: page reading
# TAVILY_API_KEY=your-tavily-api-key
# EXA_API_KEY=your-exa-api-key
# JINA_API_KEY=your-jina-api-key
# FIRECRAWL_API_KEY=your-firecrawl-api-key

# ===========================================
# 可选：AI 可观测性（Langfuse）
# ===========================================
# 功能：自动追踪 tokens、成本、延迟、工具调用
# 注册地址：https://langfuse.com/signup（免费）

# LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
# LANGFUSE_SECRET_KEY=sk-lf-your-secret-key

# ===========================================
# 可选：覆盖默认 AI 模型
# ===========================================
# 以下均有默认值，一般不需要修改

# 可选：覆盖用户可选 AI 链路的模型组合
# AI_QWEN_MODEL_INTERACTIVE=qwen3.6-plus
# AI_QWEN_MODEL_OUTLINE=qwen3.7-max
# AI_QWEN_MODEL_SECTION_DRAFT=qwen3.6-plus
# AI_QWEN_MODEL_EXTRACT=qwen3.6-flash
# AI_QWEN_MODEL_REVIEW=qwen3.7-max
# AI_QWEN_MODEL_WEB_SEARCH=qwen3.6-plus
# AI_DEEPSEEK_MODEL_INTERACTIVE=deepseek-v4-flash
# AI_DEEPSEEK_MODEL_OUTLINE=deepseek-v4-pro
# AI_DEEPSEEK_MODEL_SECTION_DRAFT=deepseek-v4-flash
# AI_DEEPSEEK_MODEL_EXTRACT=deepseek-v4-flash
# AI_DEEPSEEK_MODEL_REVIEW=deepseek-v4-pro
# AI_DEEPSEEK_MODEL_WEB_SEARCH=deepseek-v4-flash
# AI_OPENAI_MODEL_INTERACTIVE=gpt-5.5
# AI_OPENAI_MODEL_OUTLINE=gpt-5.5
# AI_OPENAI_MODEL_SECTION_DRAFT=gpt-5.5
# AI_OPENAI_MODEL_EXTRACT=gpt-5.5
# AI_OPENAI_MODEL_REVIEW=gpt-5.5
# AI_OPENAI_MODEL_WEB_SEARCH=gpt-5.5

# AI_ENABLE_WEB_SEARCH=true
# NEXT_PUBLIC_AI_ENABLE_WEB_SEARCH=true

# ===========================================
# 可选：RAG 调优参数
# ===========================================
# 以下均有默认值，仅在需要微调时修改

# EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# Must match db/schema/shared.ts vector width. Changing this is a schema migration.
# EMBEDDING_DIMENSIONS=4096
# RERANKER_MODEL=qwen3-rerank
# RERANKER_MODEL_PRO=qwen3-rerank
# RERANKER_ENABLED=true
# RAG_CHUNK_SIZE=500
# RAG_CHUNK_OVERLAP=50
# RAG_TIMEOUT=5000
# RAG_SIMILARITY_THRESHOLD=0.3
