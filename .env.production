# ===========================================
# NexusNote 环境配置 - 统一配置文件
# ===========================================

# ===========================================
# 数据库
# ===========================================
DATABASE_URL=postgresql://findbiao@localhost:5432/nexusnote

# ===========================================
# Redis（可选）
# ===========================================
REDIS_URL=redis://localhost:6380

# ===========================================
# AI 配置 - 多 Provider 架构
# ===========================================

# Chat Provider 选择 (deepseek / 302ai / siliconflow)
AI_PROVIDER=302ai

# # DeepSeek 官方 - 主要 Chat Provider
# DEEPSEEK_API_KEY=sk-1bfbdcf3220c431ca5cc1b980c796a4e

# 302.ai - Embedding & Reranker Provider
AI_302_API_KEY=sk-pKDXu78Y15URThbEc7bJibpd6QlYUjiMkTLy69w7BvPPu3P3

# Embedding 配置
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIMENSIONS=4000

# Reranker 配置
RERANKER_MODEL=Qwen/Qwen3-Reranker-8B
RERANKER_ENABLED=true

# ===========================================
# AI 可观测性 - Langfuse
# ===========================================
LANGFUSE_PUBLIC_KEY=pk-lf-a08cee96-b48e-4baf-acb8-09181b1ed62b
LANGFUSE_SECRET_KEY=sk-lf-cb55886b-280d-49d0-94fb-e66f664b79d5
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ===========================================
# RAG 高级优化（可选）
# ===========================================
QUERY_REWRITING_ENABLED=false
HYBRID_SEARCH_ENABLED=false
CONTEXT_COMPRESSION_ENABLED=false
AI_FAST_MODEL=gemini-3-flash-preview

# 硅基流动（备用）
SILICONFLOW_API_KEY=sk-srpkdxwurodpmjghnkqupxnizqqgcozemfljrrnujojmgggn

# ===========================================
# 认证（Auth.js v5）
# ===========================================
AUTH_URL=http://localhost:3000
AUTH_SECRET=nexusnote-dev-auth-js-secret-32-chars-long

# JWT 配置
JWT_SECRET=nexusnote-dev-jwt-secret-32chars

# ===========================================
# 服务地址（开发环境）
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_COLLAB_URL=ws://localhost:1234
