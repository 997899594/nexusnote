FROM node:20-alpine AS runner
WORKDIR /app

ARG GIT_SHA=unknown

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV APP_BUILD_SHA=${GIT_SHA}

# 创建非 root 用户 + 安装 dumb-init
RUN apk add --no-cache dumb-init \
    && addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 nextjs \
    && mkdir -p /app/logs && chown -R nextjs:nodejs /app

# CI 先在宿主机构建，再把最小运行时产物打进镜像。
COPY --chown=nextjs:nodejs .docker-runtime/standalone ./
COPY --chown=nextjs:nodejs .docker-runtime/static ./.next/static
COPY --chown=nextjs:nodejs .docker-runtime/lib ./lib
COPY --chown=nextjs:nodejs .docker-runtime/public ./public

# 迁移运行时仍复用同一镜像，只保留必需脚本与依赖。
COPY --chown=nextjs:nodejs .docker-runtime/drizzle ./drizzle
COPY --chown=nextjs:nodejs .docker-runtime/scripts ./scripts
COPY --chown=nextjs:nodejs .docker-runtime/node_modules/drizzle-orm ./node_modules/drizzle-orm
COPY --chown=nextjs:nodejs .docker-runtime/node_modules/postgres ./node_modules/postgres

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

ENTRYPOINT ["dumb-init", "--"]
CMD ["node", "server.js"]
