# NexusNote runtime environment example
# Copy the keys you need into your deployment platform.

NODE_ENV=production

NEXT_PUBLIC_APP_URL=https://nexusnote.example.com
AUTH_URL=https://nexusnote.example.com
AUTH_SECRET=replace-with-a-long-random-secret

DATABASE_URL=postgresql://user:password@host:5432/nexusnote
REDIS_URL=redis://:password@host:6379/0

AI_302_API_KEY=replace-me
AI_302_BASE_URL=https://api.302ai.cn/v1

# Model defaults
AI_QWEN_MODEL_INTERACTIVE=qwen3.6-plus
AI_QWEN_MODEL_OUTLINE=qwen3.7-max
AI_QWEN_MODEL_SECTION_DRAFT=qwen3.6-plus
AI_QWEN_MODEL_EXTRACT=qwen3.6-flash
AI_QWEN_MODEL_REVIEW=qwen3.7-max
AI_QWEN_MODEL_WEB_SEARCH=qwen3.6-plus
AI_DEEPSEEK_MODEL_INTERACTIVE=deepseek-v4-flash
AI_DEEPSEEK_MODEL_OUTLINE=deepseek-v4-pro
AI_DEEPSEEK_MODEL_SECTION_DRAFT=deepseek-v4-flash
AI_DEEPSEEK_MODEL_EXTRACT=deepseek-v4-flash
AI_DEEPSEEK_MODEL_REVIEW=deepseek-v4-pro
AI_DEEPSEEK_MODEL_WEB_SEARCH=deepseek-v4-flash
AI_OPENAI_MODEL_INTERACTIVE=gpt-5.5
AI_OPENAI_MODEL_OUTLINE=gpt-5.5
AI_OPENAI_MODEL_SECTION_DRAFT=gpt-5.5
AI_OPENAI_MODEL_EXTRACT=gpt-5.5
AI_OPENAI_MODEL_REVIEW=gpt-5.5
AI_OPENAI_MODEL_WEB_SEARCH=gpt-5.5
AI_ENABLE_WEB_SEARCH=true
TAVILY_API_KEY=
EXA_API_KEY=
JINA_API_KEY=
FIRECRAWL_API_KEY=
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIMENSIONS=1536
RERANKER_MODEL=qwen3-rerank
RERANKER_MODEL_PRO=qwen3-rerank
RERANKER_ENABLED=true

# Email auth
RESEND_API_KEY=
EMAIL_FROM=NexusNote <noreply@example.com>

# Optional observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Optional queue tuning
QUEUE_COURSE_PRODUCTION_CONCURRENCY=1
QUEUE_COURSE_PRODUCTION_MAX_RETRIES=2
QUEUE_COURSE_PRODUCTION_BACKOFF_DELAY=1500
QUEUE_CAREER_TREE_CONCURRENCY=1
QUEUE_CAREER_TREE_MAX_RETRIES=3
QUEUE_CAREER_TREE_BACKOFF_DELAY=1000
QUEUE_KNOWLEDGE_INSIGHTS_CONCURRENCY=1
QUEUE_KNOWLEDGE_INSIGHTS_MAX_RETRIES=3
QUEUE_KNOWLEDGE_INSIGHTS_BACKOFF_DELAY=1000
QUEUE_RAG_CONCURRENCY=3
QUEUE_RAG_MAX_RETRIES=3
QUEUE_RAG_BACKOFF_DELAY=1000
QUEUE_RESEARCH_CONCURRENCY=2
QUEUE_RESEARCH_MAX_RETRIES=2
QUEUE_RESEARCH_BACKOFF_DELAY=1500
