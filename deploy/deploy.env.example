# NexusNote runtime environment example
# Copy the keys you need into your deployment platform.

NODE_ENV=production

NEXT_PUBLIC_APP_URL=https://nexusnote.example.com
AUTH_URL=https://nexusnote.example.com
AUTH_SECRET=replace-with-a-long-random-secret

DATABASE_URL=postgresql://user:password@host:5432/nexusnote
REDIS_URL=redis://:password@host:6379/0

AI_302_API_KEY=replace-me
AI_302_BASE_URL=https://api.302.ai/v1

# Optional fallback providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=

# Model defaults
AI_MODEL=gemini-3.1-flash-lite-preview
AI_MODEL_PRO=gemini-3.1-pro-preview
AI_MODEL_WEB_SEARCH=gemini-3.1-flash-lite-preview
AI_FALLBACK_MODEL=gpt-4.1-mini
AI_FALLBACK_MODEL_PRO=gpt-4.1
AI_FALLBACK_MODEL_WEB_SEARCH=gpt-4.1-mini
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
RERANKER_MODEL=Qwen/Qwen3-Reranker-4B
RERANKER_MODEL_PRO=Qwen/Qwen3-Reranker-8B

# Email auth
RESEND_API_KEY=
EMAIL_FROM=NexusNote <noreply@example.com>

# Optional observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
