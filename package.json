{
  "name": "nexusnote",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "bun ./node_modules/.bin/next dev --turbo --port 3000",
    "build": "bun ./node_modules/.bin/next build",
    "start": "node scripts/start.mjs",
    "lint": "biome check .",
    "typecheck": "bun ./node_modules/.bin/next typegen && tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.scripts.json",
    "check:research-routing": "bun scripts/check-research-routing.ts",
    "check:worker-runtime": "bun scripts/check-worker-runtime-boundary.ts",
    "build:worker-runtime": "bun scripts/build-worker-runtime.ts",
    "ai:eval": "bun scripts/run-ai-evals.ts",
    "ai:eval:interview-speed": "bun scripts/run-interview-speed-eval.ts",
    "billing:create-code": "bun scripts/create-redeem-code.ts",
    "db:cleanup-retired-ai-model-series": "bun scripts/cleanup-retired-ai-model-series.ts",
    "worker:all": "bun scripts/start-workers.ts",
    "worker:career-tree": "bun scripts/start-career-tree-worker.ts",
    "worker:course-production": "bun scripts/start-course-production-worker.ts",
    "worker:knowledge-insights": "bun scripts/start-knowledge-insights-worker.ts",
    "worker:note-followups": "bun scripts/start-note-followups-worker.ts",
    "worker:rag": "bun scripts/start-rag-worker.ts",
    "worker:research": "bun scripts/start-research-worker.ts",
    "db:hash": "atlas migrate hash --dir file://migrations",
    "db:validate": "atlas migrate validate --dir file://migrations --dev-url docker://pgvector/pg16/dev?search_path=public",
    "db:push": "atlas migrate apply --env local --revisions-schema public",
    "db:studio": "drizzle-kit studio --config drizzle.config.mjs"
  },
  "engines": {
    "node": ">=20.9.0",
    "bun": ">=1.3.9"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.84",
    "@ai-sdk/provider": "^3.0.14",
    "@ai-sdk/react": "^3.0.226",
    "@auth/drizzle-adapter": "^1.11.2",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-slot": "^1.3.0",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@tiptap/extension-highlight": "3.27.3",
    "@tiptap/extension-image": "3.27.3",
    "@tiptap/extension-link": "3.27.3",
    "@tiptap/extension-placeholder": "3.27.3",
    "@tiptap/extension-task-item": "3.27.3",
    "@tiptap/extension-task-list": "3.27.3",
    "@tiptap/extension-text-style": "3.27.3",
    "@tiptap/extension-underline": "3.27.3",
    "@tiptap/react": "3.27.3",
    "@tiptap/starter-kit": "3.27.3",
    "@xyflow/react": "^12.11.2",
    "ai": "6.0.224",
    "babel-plugin-react-compiler": "^1.0.0",
    "bullmq": "^5.80.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "elkjs": "^0.11.1",
    "framer-motion": "^12.42.2",
    "ioredis": "^5.11.1",
    "katex": "^0.16.47",
    "lucide-react": "^0.475.0",
    "next": "^16.2.10",
    "next-auth": "5.0.0-beta.30",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resumable-stream": "^2.2.12",
    "server-only": "^0.0.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@esbuild/linux-x64": "0.25.12",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.14",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.18",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "ws": "^8.20.1"
  }
}
